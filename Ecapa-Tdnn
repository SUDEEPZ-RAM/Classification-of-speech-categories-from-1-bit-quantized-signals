pec = tf.tensordot(power_spec, self.mel_matrix, axes=1)\n        log_mel = tf.math.log(mel_spec + 1e-6)\n        mean = tf.reduce_mean(log_mel, axis=1, keepdims=True)\n        return log_mel - mean","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T05:59:12.589887Z","iopub.execute_input":"2026-07-21T05:59:12.590149Z","iopub.status.idle":"2026-07-21T05:59:12.597144Z","shell.execute_reply.started":"2026-07-21T05:59:12.590127Z","shell.execute_reply":"2026-07-21T05:59:12.596407Z"}},"outputs":[],"execution_count":3},{"cell_type":"code","source":"class WaveformAugment(layers.Layer):\n    def __init__(self, noise_std=0.001, gain_range=(0.97, 1.03), **kwargs):\n        super().__init__(**kwargs)\n        self.noise_std = noise_std\n        self.gain_range = gain_range\n\n    def call(self, x, training=False):\n        if not training:\n            return x\n        noise = tf.random.normal(tf.shape(x), stddev=self.noise_std)\n        x = x + noise\n        batch_size = tf.shape(x)[0]\n        gain = tf.random.uniform([batch_size, 1, 1], self.gain_range[0], self.gain_range[1])\n        return x * gain","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T06:11:31.827733Z","iopub.execute_input":"2026-07-21T06:11:31.828030Z","iopub.status.idle":"2026-07-21T06:11:31.834323Z","shell.execute_reply.started":"2026-07-21T06:11:31.828004Z","shell.execute_reply":"2026-07-21T06:11:31.833606Z"}},"outputs":[],"execution_count":23},{"cell_type":"code","source":"class TDNNBlock(layers.Layer):\n    def __init__(self, channels, kernel_size, dilation, weight_decay=1e-4, dropout=0.0, **kwargs):\n        super().__init__(**kwargs)\n        self.conv = layers.Conv1D(\n            channels, kernel_size=kernel_size, dilation_rate=dilation,\n            padding=\"same\", kernel_regularizer=regularizers.l2(weight_decay)\n        )\n        self.bn = layers.BatchNormalization()\n        self.prelu = layers.PReLU(shared_axes=[1])\n        self.dropout = layers.Dropout(dropout) if dropout > 0 else None\n\n    def call(self, x, training=False):\n        x = self.conv(x)\n        x = self.bn(x, training=training)\n        x = self.prelu(x)\n        if self.dropout is not None:\n            x = self.dropout(x, training=training)\n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T05:59:31.269578Z","iopub.execute_input":"2026-07-21T05:59:31.270038Z","iopub.status.idle":"2026-07-21T05:59:31.276135Z","shell.execute_reply.started":"2026-07-21T05:59:31.270008Z","shell.execute_reply":"2026-07-21T05:59:31.275258Z"}},"outputs":[],"execution_count":5},{"cell_type":"code","source":"class SEBlock(layers.Layer):\n    def __init__(self, channels, bottleneck=64, **kwargs):\n        super().__init__(**kwargs)\n        self.pool = layers.GlobalAveragePooling1D()\n        self.fc1 = layers.Dense(bottleneck, activation=\"relu\")\n        self.fc2 = layers.Dense(channels, activation=\"sigmoid\")\n\n    def call(self, x):\n        s = self.pool(x)\n        s = self.fc1(s)\n        s = self.fc2(s)\n        return x * tf.expand_dims(s, axis=1)\n\n\nclass Res2Block(layers.Layer):\n    def __init__(self, channels, scale=8, kernel_size=3, dilation=2, weight_decay=1e-4, **kwargs):\n        super().__init__(**kwargs)\n        self.scale = scale\n        self.width = channels // scale\n        self.convs = [\n            layers.Conv1D(self.width, kernel_size=kernel_size, dilation_rate=dilation,\n                           padding=\"same\", kernel_regularizer=regularizers.l2(weight_decay))\n            for _ in range(scale - 1)\n        ]\n        self.bns = [layers.BatchNormalization() for _ in range(scale - 1)]\n        self.prelus = [layers.PReLU(shared_axes=[1]) for _ in range(scale - 1)]\n\n    def call(self, x, training=False):\n        splits = tf.split(x, self.scale, axis=-1)\n        outputs = [splits[0]]\n        prev = None\n        for i in range(1, self.scale):\n            xi = splits[i] if prev is None else splits[i] + prev\n            xi = self.convs[i-1](xi)\n            xi = self.bns[i-1](xi, training=training)\n            xi = self.prelus[i-1](xi)\n            outputs.append(xi)\n            prev = xi\n        return tf.concat(outputs, axis=-1)\n\n\nclass SERes2Block(layers.Layer):\n    def __init__(self, channels, scale=8, dilation=2, weight_decay=1e-4, dropout=0.0, **kwargs):\n        super().__init__(**kwargs)\n        self.tdnn1 = TDNNBlock(channels, kernel_size=1, dilation=1, weight_decay=weight_decay)\n        self.res2 = Res2Block(channels, scale=scale, kernel_size=3, dilation=dilation, weight_decay=weight_decay)\n        self.tdnn2 = TDNNBlock(channels, kernel_size=1, dilation=1, weight_decay=weight_decay)\n        self.se = SEBlock(channels)\n        self.dropout = layers.SpatialDropout1D(dropout) if dropout > 0 else None\n\n    def call(self, x, training=False):\n        residual = x\n        out = self.tdnn1(x, training=training)\n        out = self.res2(out, training=training)\n        out = self.tdnn2(out, training=training)\n        out = self.se(out)\n        if self.dropout is not None:\n            out = self.dropout(out, training=training)\n        return out + residual","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T05:59:46.977205Z","iopub.execute_input":"2026-07-21T05:59:46.977646Z","iopub.status.idle":"2026-07-21T05:59:46.989046Z","shell.execute_reply.started":"2026-07-21T05:59:46.977617Z","shell.execute_reply":"2026-07-21T05:59:46.988428Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"class AttentiveStatisticsPooling(layers.Layer):\n    def __init__(self, channels, bottleneck=64, **kwargs):\n        super().__init__(**kwargs)\n        self.conv1 = layers.Conv1D(bottleneck, kernel_size=1, activation=\"tanh\")\n        self.conv2 = layers.Conv1D(channels, kernel_size=1, activation=\"softmax\")\n\n    def call(self, x):\n        attn = self.conv1(x)\n        attn = self.conv2(attn)\n        mean = tf.reduce_sum(x * attn, axis=1)\n        var = tf.reduce_sum((x ** 2) * attn, axis=1) - mean ** 2\n        std = tf.sqrt(tf.maximum(var, 1e-8))\n        return tf.concat([mean, std], axis=-1)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T05:59:56.558530Z","iopub.execute_input":"2026-07-21T05:59:56.558934Z","iopub.status.idle":"2026-07-21T05:59:56.564432Z","shell.execute_reply.started":"2026-07-21T05:59:56.558907Z","shell.execute_reply":"2026-07-21T05:59:56.563595Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"def build_ecapa_tdnn(input_len=16000, num_classes=4, n_mels=64,\n                      channels=256, agg_channels=512,\n                      weight_decay=1e-4, block_dropout=0.10,\n                      embed_dropout=0.25, use_augment=True):\n\n    inputs = layers.Input(shape=(input_len, 1), name=\"waveform\")\n\n    x = inputs\n    if use_augment:\n        x = WaveformAugment()(x)\n\n    x = LogMelSpectrogram(sr=SR, n_mels=n_mels, win_ms=WIN_MS, hop_ms=HOP_MS)(x)\n\n    # Layer 1: initial TDNN — MUST output `channels`, not a fixed 128,\n    # since the SE-Res2 blocks' residual connection needs matching shapes\n    x = TDNNBlock(channels, kernel_size=5, dilation=1,\n                  weight_decay=weight_decay, dropout=block_dropout)(x)\n\n    # Layers 2-4: three SE-Res2 blocks at `channels` width\n    b1 = SERes2Block(channels, scale=8, dilation=2, weight_decay=weight_decay, dropout=block_dropout)(x)\n    b2 = SERes2Block(channels, scale=8, dilation=3, weight_decay=weight_decay, dropout=block_dropout)(b1)\n    b3 = SERes2Block(channels, scale=8, dilation=4, weight_decay=weight_decay, dropout=block_dropout)(b2)\n\n    # Layer 5: aggregation -> agg_channels\n    x = layers.Concatenate(axis=-1)([b1, b2, b3])\n    x = TDNNBlock(agg_channels, kernel_size=1, dilation=1, weight_decay=weight_decay)(x)\n\n    # Layer 6: attentive statistics pooling\n    x = AttentiveStatisticsPooling(channels=agg_channels)(x)\n    x