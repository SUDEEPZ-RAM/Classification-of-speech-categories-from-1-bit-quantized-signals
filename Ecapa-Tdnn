      for _ in range(scale - 1):\n\n            self.blocks.append(\n\n                models.Sequential([\n\n                    layers.Conv1D(\n                        self.width,\n                        kernel_size,\n                        dilation_rate=dilation,\n                        padding=\"same\",\n                        use_bias=False,\n                        kernel_initializer=\"he_normal\",\n                        kernel_regularizer=regularizers.l2(weight_decay)\n                    ),\n\n                    layers.BatchNormalization(),\n\n                    layers.ReLU()\n\n                ])\n\n            )\n\n    def call(self, x, training=False):\n\n        splits = tf.split(x, self.scale, axis=-1)\n\n        outputs = [splits[0]]\n\n        running = splits[0]\n\n        for i in range(1, self.scale):\n\n            running = running + splits[i]\n\n            running = self.blocks[i-1](running, training=training)\n\n            outputs.append(running)\n\n        return tf.concat(outputs, axis=-1)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.014832Z","iopub.execute_input":"2026-07-18T14:04:31.015201Z","iopub.status.idle":"2026-07-18T14:04:31.024841Z","shell.execute_reply.started":"2026-07-18T14:04:31.015177Z","shell.execute_reply":"2026-07-18T14:04:31.023858Z"}},"outputs":[],"execution_count":70},{"cell_type":"code","source":"# ============================================================\n# Verify Res2Net Block\n# ============================================================\n\ndummy = tf.random.normal((4,98,256))\n\nblock = Res2NetBlock(\n    channels=256,\n    scale=4\n)\n\ny = block(dummy)\n\nprint(\"=\"*60)\nprint(\"Input :\",dummy.shape)\nprint(\"Output:\",y.shape)\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.026131Z","iopub.execute_input":"2026-07-18T14:04:31.026588Z","iopub.status.idle":"2026-07-18T14:04:31.283577Z","shell.execute_reply.started"