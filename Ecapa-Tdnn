       self.fc1 = layers.Dense(\n            channels // reduction,\n            activation=\"relu\",\n            kernel_initializer=\"he_normal\",\n            kernel_regularizer=regularizers.l2(weight_decay)\n        )\n\n        self.fc2 = layers.Dense(\n            channels,\n            activation=\"sigmoid\",\n            kernel_initializer=\"he_normal\",\n            kernel_regularizer=regularizers.l2(weight_decay)\n        )\n\n    def call(self, x):\n\n        w = self.pool(x)\n\n        w = self.fc1(w)\n\n        w = self.fc2(w)\n\n        w = tf.expand_dims(w, axis=1)\n\n        return x * w\n\n    def get_config(self):\n        return super().get_config()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.457068Z","iopub.execute_input":"2026-07-18T14:04:31.457638Z","iopub.status.idle":"2026-07-18T14:04:31.465802Z","shell.execute_reply.started":"2026-07-18T14:04:31.457607Z","shell.execute_reply":"2026-07-18T14:04:31.464583Z"}},"outputs":[],"execution_count":73},{"cell_type":"code","source":"# ============================================================\n# Verify SE Block\n# ============================================================\n\ndummy = tf.random.normal((4,98,256))\n\nse = SEBlock(\n    channels=256,\n    reduction=8\n)\n\ny = se(dummy)\n\nprint(\"=\"*60)\nprint(\"Input :\", dummy.shape)\nprint(\"Output:\", y.shape)\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.467034Z","iopub.execute_input":"2026-07-18T14:04:31.46758Z","iopub.status.idle":"2026-07-18T14:04:31.543916Z","shell.execute_reply.started":"2026-07-18T14:04:31.467504Z","shell.execute_reply":"2026-07-18T14:04:31.542966Z"}},"outputs":[{"name":"stdout","text":"============================================================\nInput : (4, 98, 256)\nOutput: (4, 98, 256)\n============================================================\n","output_type":"stream"}],"execution_count":74},{"cell_type":"code","source":"# ============================================================\n# SECTION 6 : SE-Res2 Block\n# ============================================================\n\nclass SERes2Block(layers.Layer):\n\n    def __init__(\n        self,\n        channels=256,\n        scale=4,\n        dilation=2,\n        dropout=0.2,\n        weight_decay=1e-4,\n        **kwargs\n    ):\n        super().__init__(**kwargs)\n\n        self.tdnn1 = TDNNBlock(\n            channels=channels,\n            kernel_size=1,\n            dilation=1,\n            dropout=0.0,\n            weight_decay=weight_decay\n        )\n\n        self.res2 = Res2NetBlock(\n            channels=channels,\n            scale=scale,\n            kernel_size=3,\n            dilation=dilation,\n            weight_decay=weight_decay\n        )\n\n        self.tdnn2 = TDNNBlock(\n            channels=channels,\n            kernel_size=1,\n            dilation=1,\n            dropout=dropout,\n            weight_decay=weight_decay\n        )\n\n        self.se = SEBlock(\n            channels=channels,\n            reduction=8,\n            weight_decay=weight_decay\n        )\n\n    def call(self, x, training=False):\n\n        identity = x\n\n        out = self.tdnn1(x, training=training)\n\n        out = self.res2(out, training=training)\n\n        out = self.tdnn2(out, training=training)\n\n        out = self.se(out)\n\n        out = out + identity\n\n        return tf.nn.relu(out)\n\n    def get_config(self):\n        return super().get_config()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.545062Z","iopub.execute_input":"2026-07-18T14:04:31.545678Z","iopub.status.idle":"2026-07-18T14:04:31.554716Z","shell.execute_reply.started":"2026-07-18T14:04:31.545651Z","shell.execute_reply":"2026-07-18T14:04:31.553642Z"}},"outputs":[],"execution_count":75},{"cell_type":"code","source":"# ============================================================\n# Verify SE-Res2 Block\n# ============================================================\n\ndummy = tf.random.normal((4,98,256))\n\nblock = SERes2Block(\n    channels=256,\n    scale=4,\n    dilation=2\n)\n\ny = block(dummy)\n\nprint(\"=\"*60)\nprint(\"Input :\", dummy.shape)\nprint(\"Output:\", y.shape)\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:31.555828Z","iopub.execute_input":"2026-07-18T14:04:31.55607Z","iopub.status.idle":"2026-07-18T14:04:32.001341Z","shell.execute_reply.started":"2026-07-18T14:04:31.556048Z","shell.execute_reply":"2026-07-18T14:04:32.000494Z"}},"outputs":[{"name":"stdout","text":"============================================================\nInput : (4, 98, 256)\nOutput: (4, 98, 256)\n============================================================\n","output_type":"stream"}],"execution_count":76},{"cell_type":"code","source":"# ============================================================\n# SECTION 7 : Attentive Statistics Pooling\n# ============================================================\n\nclass AttentiveStatisticsPooling(layers.Layer):\n    \"\"\"\n    Attentive Statistics Pooling (ASP)\n\n    Computes:\n        - Attention-weighted Mean\n        - Attention-weighted Standard Deviation\n\n    Output Dimension:\n        2 Г— Channels\n    \"\"\"\n\n    def __init__(\n        self,\n        channels,\n        attention_channels=128,\n        weight_decay=1e-4,\n        **kwargs\n    ):\n        super().__init__(**kwargs)\n\n        self.attention = models.Sequential([\n\n            layers.Conv1D(\n                attention_channels,\n                kernel_size=1,\n                padding=\"same\",\n                activation=\"relu\",\n                kernel_initializer=\"he_normal\",\n                kernel_regularizer=regularizers.l2(weight_decay)\n            ),\n\n            layers.BatchNormalization(),\n\n            layers.Conv1D(\n                channels,\n                kernel_size=1,\n                padding=\"same\",\n                kernel_initializer=\"he_normal\",\n                kernel_regularizer=regularizers.l2(weight_decay)\n            )\n\n        ])\n\n    def call(self, x, training=False):\n\n        # (B,T,C)\n        att = self.attention(x, training=training)\n\n        # Softmax over time\n        att = tf.nn.softmax(att, axis=1)\n\n        # Weighted Mean\n        mean = tf.reduce_sum(att * x, axis=1)\n\n        # Weighted Variance\n        var = tf.reduce_sum(att * tf.square(x - tf.expand_dims(mean,1)), axis=1)\n\n        std = tf.sqrt(var + 1e-6)\n\n        pooled = tf.concat([mean, std], axis=-1)\n\n        return pooled\n\n    def get_config(self):\n        return super().get_config()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:32.002368Z","iopub.execute_input":"2026-07-18T14:04:32.002741Z","iopub.status.idle":"2026-07-18T14:04:32.011119Z","shell.execute_reply.started":"2026-07-18T14:04:32.002714Z","shell.execute_reply":"2026-07-18T14:04:32.010353Z"}},"outputs":[],"execution_count":77},{"cell_type":"code","source":"# ============================================================\n# Verify ASP\n# ============================================================\n\ndummy = tf.random.normal((4,98,256))\n\nasp = AttentiveStatisticsPooling(channels=256)\n\ny = asp(dummy)\n\nprint(\"=\"*60)\nprint(\"Input :\",dummy.shape)\nprint(\"Output:\",y.shape)\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:32.012438Z","iopub.execute_input":"2026-07-18T14:04:32.013067Z","iopub.status.idle":"2026-07-18T14:04:32.154191Z","shell.execute_reply.started":"2026-07-18T14:04:32.013033Z","shell.execute_reply":"2026-07-18T14:04:32.153126Z"}},"outputs":[{"name":"stdout","text":"============================================================\nInput : (4, 98, 256)\nOutput: (4, 512)\n============================================================\n","output_type":"stream"}],"execution_count":78},{"cell_type":"code","source":"# ============================================================\n# SECTION 8 : Multi-layer Feature Aggregation\n# ============================================================\n\nclass FeatureAggregation(layers.Layer):\n\n    def __init__(\n        self,\n        out_channels=256,\n        weight_decay=1e-4,\n        **kwargs\n    ):\n        super().__init__(**kwargs)\n\n        self.conv = layers.Conv1D(\n            out_channels,\n            kernel_size=1,\n            padding=\"same\",\n            use_bias=False,\n            kernel_initializer=\"he_normal\",\n            kernel_regularizer=regularizers.l2(weight_decay)\n        )\n\n        self.bn = layers.BatchNormalization()\n\n        self.relu = layers.ReLU()\n\n    def call(self, features, training=False):\n\n        x = tf.concat(features, axis=-1)\n\n        x = self.conv(x)\n\n        x = self.bn(x, training=training)\n\n        x = self.relu(x)\n\n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:32.155494Z","iopub.execute_input":"2026-07-18T14:04:32.155856Z","iopub.status.idle":"2026-07-18T14:04:32.163748Z","shell.execute_reply.started":"2026-07-18T14:04:32.155831Z","shell.execute_reply":"2026-07-18T14:04:32.16246Z"}},"outputs":[],"execution_count":79},{"cell_type":"code","source":"# ============================================================\n# Verify Feature Aggregation\n# ============================================================\n\nf1 = tf.random.normal((4,98,256))\nf2 = tf.random.normal((4,98,256))\nf3 = tf.random.normal((4,98,256))\n\nagg = FeatureAggregation()\n\ny = agg([f1,f2,f3])\n\nprint(\"=\"*60)\nprint(\"Output Shape :\",y.shape)\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:32.164888Z","iopub.execute_input":"2026-07-18T14:04:32.165267Z","iopub.status.idle":"2026-07-18T14:04:32.23716Z","shell.execute_reply.started":"2026-07-18T14:04:32.165228Z","shell.execute_reply":"2026-07-18T14:04:32.236385Z"}},"outputs":[{"name":"stdout","text":"============================================================\nOutput Shape : (4, 98, 256)\n============================================================\n","output_type":"stream"}],"execution_count":80},{"cell_type":"code","source":"# ============================================================\n# FINAL ECAPA-TDNN MODEL (now configurable for regularization)\n# ============================================================\n\ndef build_ecapa_tdnn(\n    block_dropout=0.10,\n    embed_dropout=0.30,\n    weight_decay=1e-4,\n    spatial_dropout_res2=0.0   # extra dropout inside Res2/SE path, 0 = off\n):\n\n    inputs = layers.Input(shape=(16000, 1), name=\"waveform\")\n\n    x = LogMelSpectrogram()(inputs)\n   \n    x = TDNNBlock(\n        channels=256,\n        kernel_size=5,\n        dilation=1,\n        dropout=block_dropout,\n        weight_decay=weight_decay\n    )(x)\n\n    b1 = SERes2Block(\n        channels=256, scale=4, dilation=2,\n        dropout=block_dropout, weight_decay=weight_decay\n    )(x)\n\n    b2 = SERes2Block(\n        channels=256, scale=4, dilation=3,\n        dropout=block_dropout, weight_decay=weight_decay\n    )(b1)\n\n    b3 = SERes2Block(\n        channels=256, scale=4, dilation=4,\n        dropout=block_dropout, weight_decay=weight_decay\n    )(b2)\n\n    x = layers.Concatenate(axis=-1)([b1, b2, b3])\n\n    x = TDNNBlock(\n        channels=256, kernel_size=1, dilation=1,\n        dropout=block_dropout, weight_decay=weight_decay\n    )(x)\n\n    x = AttentiveStatisticsPooling(channels=256)(x)\n\n    x = layers.BatchNormalization(momentum=0.95, epsilon=1e-5)(x)\n\n    x = layers.Dense(\n        192,\n        kernel_initializer=\"he_normal\",\n        kernel_regularizer=regularizers.l2(weight_decay)\n    )(x)\n\n    x = layers.BatchNormalization(momentum=0.95, epsilon=1e-5)(x)\n    x = layers.Activation(\"swish\")(x)\n    x = layers.Dropout(embed_dropout)(x)\n\n    outputs = layers.Dense(\n        NUM_C