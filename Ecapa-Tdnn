 = tf.tensordot(\n            magnitude,\n            self.mel_weight_matrix,\n            axes=1\n        )\n\n        mel.set_shape(\n            magnitude.shape[:-1].concatenate(\n                self.mel_weight_matrix.shape[-1:]\n            )\n        )\n\n        logmel = tf.math.log(mel + 1e-6)\n\n        # Per-utterance CMN\n        mean = tf.reduce_mean(logmel, axis=1, keepdims=True)\n        logmel = logmel - mean\n\n        return logmel\n\n    def get_config(self):\n        config = super().get_config()\n        config.update({\n            \"sample_rate\": self.sample_rate,\n            \"frame_length\": self.frame_length,\n            \"frame_step\": self.frame_step,\n            \"fft_length\": self.fft_length,\n            \"num_mel_bins\": self.num_mel_bins,\n            \"fmin\": self.fmin,\n            \"fmax\": self.fmax,\n        })\n        return config","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:30.76927Z","iopub.execute_input":"2026-07-18T14:04:30.769696Z","iopub.status.idle":"2026-07-18T14:04:30.780555Z","shell.execute_reply.started":"2026-07-18T14:04:30.769672Z","shell.execute_reply":"2026-07-18T14:04:30.779404Z"}},"outputs":[],"execution_count":66},{"cell_type":"code","source":"# ============================================================\n# Verify Log-Mel Layer\n# ============================================================\n\nfrontend = LogMelSpectrogram()\n\ndummy = tf.random.normal((2,16000,1))\n\nmel = frontend(dummy)\n\nprint(\"=\"*60)\nprint(\"Input Shape :\", dummy.shape)\nprint(\"Output Shape:\", mel.shape)\nprint(\"=\"*60)\n\nprint(\"Min :\", tf.reduce_min(mel).numpy())\nprint(\"Max :\", tf.reduce_max(mel).numpy())\nprint(\"Mean:\", tf.reduce_mean(mel).numpy())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T14:04:30.781964Z","iopub.execute_input":"2026-07-18T14:04:30.782954Z","iopub.status.idle":"2026-07-18T14:04:30.91943Z","shell.execute_reply.started":"2026-07-18T14